# -----------------------------------------------------------------------------
# Root environment file used by docker-compose.yml
# Copy to .env:  cp .env.example .env
# -----------------------------------------------------------------------------

# PostgreSQL
POSTGRES_USER=agripulse
POSTGRES_PASSWORD=agripulse
POSTGRES_DB=agripulse
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=4000
# Connection string used by the backend container (host = postgres service name)
DATABASE_URL=postgresql://agripulse:agripulse@postgres:5432/agripulse?schema=public

# The demo device id the simulator should attach to (matches the seed)
DEMO_DEVICE_ID=demo-device-1

# Weather (Open-Meteo, no key needed). Default location = a sample farm.
WEATHER_LATITUDE=12.9716
WEATHER_LONGITUDE=77.5946
WEATHER_POLL_INTERVAL_MS=900000

# Simulator
SIM_TICK_INTERVAL_MS=2000

# Backend environment - copy to .env:  cp .env.example .env

# Server
NODE_ENV=development
PORT=4000

# PostgreSQL connection (local dev points at Docker-exposed Postgres on localhost)
DATABASE_URL=postgresql://agripulse:agripulse@localhost:5432/agripulse?schema=public

# Demo device id created by the seed and used by the simulator
DEMO_DEVICE_ID=demo-device-1

# Weather. Default = sample farm coordinates (Bengaluru, IN).
WEATHER_LATITUDE=12.9716
WEATHER_LONGITUDE=77.5946
# 'simulated' = generate a time-varying rain probability locally (default, good
# for demos - it drifts and periodically triggers AUTO-mode skips).
# 'live'      = fetch the real forecast from Open-Meteo.
WEATHER_MODE=simulated
# How often weather (rain probability) refreshes (ms). Default 10 min.
# Lower it (e.g. 120000 = 2 min) to see rain change faster in a demo.
WEATHER_UPDATE_INTERVAL_MS=600000

# On boot: run `prisma migrate deploy` and seed automatically (used in Docker).
# For local dev you normally run these manually, so leave them false.
RUN_MIGRATIONS_ON_START=false
SEED_ON_START=false

# CORS origin allow-list (comma separated). * allows everything (fine for dev).
CORS_ORIGIN=*

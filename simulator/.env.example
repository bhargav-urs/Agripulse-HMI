# Simulator environment - copy to .env:  cp .env.example .env

# Where the backend is reachable (Socket.IO).
BACKEND_URL=http://localhost:4000

# The device id this simulator impersonates (must exist in the DB / seed).
DEVICE_ID=demo-device-1

# How often the simulator publishes telemetry (ms).
SIM_TICK_INTERVAL_MS=2000

# Simulated-clock speed vs real time (drives the daily temperature curve):
#   1   = real time          120 = a full simulated day in ~12 minutes (good for demos)
SIM_TIME_SCALE=120

# Optional: pin the starting hour (0-24). Omit to start at the real local hour.
# SIM_START_HOUR=8

# Random network-drop faults. Off by default (trigger manually with the 'd' key).
ENABLE_FAULTS=false
